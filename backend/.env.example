# Copy this to backend/.env and fill in. Never commit the real .env.

APP_NAME=AI Plan Checker
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe (test keys for dev, live for production)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_UNLIMITED=

# Application
REQUIRE_AUTH=true
MAX_UPLOAD_SIZE_MB=100
FRONTEND_URL=http://localhost:3001

# Observability + email (optional)
SENTRY_DSN=
RESEND_API_KEY=
SUPPORT_EMAIL=esmith.marc@gmail.com

LOG_LEVEL=INFO
LOG_FORMAT=text
