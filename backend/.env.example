# Copy this to backend/.env and fill in. Never commit the real .env.

APP_NAME=AI Plan Checker
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe (test keys for dev, live for production)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_UNLIMITED=

# Application
REQUIRE_AUTH=true
MAX_UPLOAD_SIZE_MB=100
FRONTEND_URL=http://localhost:3001

# Observability + email (optional)
SENTRY_DSN=
RESEND_API_KEY=
SUPPORT_EMAIL=esmith.marc@gmail.com

# AWS Textract — OCR fallback for image-only / scanned plan sheets. Off by
# default. Cost only if enabled AND a page's text layer is too thin.
AWS_TEXTRACT_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
TEXTRACT_MIN_CHARS_PER_PAGE=200
# 0 = no cap (every thin page gets OCR'd). Set a positive integer to bound spend per plan.
TEXTRACT_MAX_PAGES=0

# Playwright Cloudflare fallback for ingest scrapers (amlegal, municode,
# qcode, ecode360). Off by default — turning this on is an operational
# decision the operator owns (ToS-gray, slower than httpx, heavier runtime).
# After enabling, install Chromium once: `playwright install chromium`.
PLAYWRIGHT_ENABLED=false
PLAYWRIGHT_USER_AGENT=
PLAYWRIGHT_DELAY_SEC=2.0
PLAYWRIGHT_TIMEOUT_SEC=60

# Standard correction checklists — inject published plan-check correction-list
# items so coverage matches a real plan check. On by default. Raise the cap for
# more depth, lower it if false positives creep in (per-department item cap).
CHECKLIST_REVIEW_ENABLED=true
CHECKLIST_MAX_PER_DEPARTMENT=40

LOG_LEVEL=INFO
LOG_FORMAT=text
